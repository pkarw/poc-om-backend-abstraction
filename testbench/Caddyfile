# Testbench reverse proxy — routes ported module APIs to the .NET service,
# everything else to the real Open Mercato app. Regenerate the matcher below
# from MODULES.md with ./gen-proxy.sh when you port another module.
#
# Architecture: OM and the .NET API SHARE one Postgres. OM MIGRATES the full schema
# (migrate-only, no `mercato init`); the .NET API runs migrations-off
# (OM_SKIP_MIGRATIONS=1) but SEEDS it (OM_SEED_ON_BOOT=1) and serves its ported
# modules. Both share JWT_SECRET and the email-hash pepper, so a JWT/session issued
# by .NET is accepted by OM's server components and vice versa.
#
# NOTE: `/api/auth/admin/nav` is a frontend-registry concern (OM's backend sidebar is
# built from its React page.meta files) and MUST stay on OM — the API-only .NET port
# cannot know OM's pages, so its nav returns empty groups. See the exception below.

{
	admin off
	auto_https off
}

:80 {
	# --- BEGIN generated ported-module routes (./gen-proxy.sh) ---
	# Frontend-chrome exception: the backend sidebar/nav is built from OM's frontend page
	# registry (its React `page.meta` files), which the API-only .NET port cannot know — its
	# /api/auth/admin/nav returns empty `groups`, so the sidebar would show no module items.
	# Keep it on OM even though `auth` is ported. Must precede @ported (first match wins).
	@om_frontend path /api/auth/admin/nav
	handle @om_frontend {
		reverse_proxy om-app:3000
	}
	@ported path /api/auth/* /api/directory/* /api/dashboards/* /api/entities/* /api/query_index/* /api/dictionaries/* /api/currencies/* /api/customers/*
	handle @ported {
		reverse_proxy dotnet-api:8080
	}
	# --- END generated ported-module routes ---

	# Everything else (OM pages, its server components, and all non-ported /api/*)
	handle {
		reverse_proxy om-app:3000
	}

	log {
		output stdout
		format console
	}
}
