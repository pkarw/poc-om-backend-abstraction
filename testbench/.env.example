# Testbench configuration. Copy to `.env` and adjust.
# JWT_SECRET and LOOKUP_HASH_PEPPER MUST be identical for om-app and the .NET
# services — that is what makes auth interchangeable across the two runtimes.

TESTBENCH_PORT=8088

POSTGRES_USER=mercato
POSTGRES_PASSWORD=mercato
POSTGRES_DB=mercato

# Shared secrets (CHANGE THESE). Same value in OM and .NET.
JWT_SECRET=testbench-shared-secret-change-me
LOOKUP_HASH_PEPPER=testbench-shared-pepper-change-me

# The Open Mercato app image. Build it from your open-mercato checkout:
#   cd <open-mercato> && docker build -t open-mercato/app:local .
OM_APP_IMAGE=open-mercato/app:local

# Seed identity (OM's `mercato init`). superadmin@acme.com / secret by default.
OM_INIT_SUPERADMIN_EMAIL=superadmin@acme.com
OM_INIT_SUPERADMIN_PASSWORD=secret
