# Production deployment config. Copy to deploy/.env and fill in.
#   cp deploy/.env.example deploy/.env
#
# Generate the three secrets once and keep them stable (rotating them invalidates existing
# sessions and makes already-encrypted PII unreadable):
#   openssl rand -hex 32     # for each of JWT_SECRET / LOOKUP_HASH_PEPPER / TENANT_DATA_ENCRYPTION_KEY

# ---- Public URL + TLS -------------------------------------------------------------------------
# Your domain (an A record must point at this server's public IP). Caddy provisions HTTPS for it.
DOMAIN=erp.example.com
LETSENCRYPT_EMAIL=you@example.com

# ---- Database ---------------------------------------------------------------------------------
POSTGRES_USER=mercato
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=mercato

# ---- Shared secrets (MUST be identical for OM + .NET; this is what makes them interoperable) ---
JWT_SECRET=change-me-openssl-rand-hex-32
LOOKUP_HASH_PEPPER=change-me-openssl-rand-hex-32
TENANT_DATA_ENCRYPTION_KEY=change-me-openssl-rand-hex-32

# ---- AI (the assistant, vector search embeddings and OCR) -------------------------------------
# Leave OPENAI_API_KEY blank to run without AI features. Set it to enable the assistant.
OPENAI_API_KEY=
# Optional alternative embedding/generation provider.
GOOGLE_GENERATIVE_AI_API_KEY=
OCR_MODEL=gpt-4o-mini

# ---- Seed identity (first boot) ---------------------------------------------------------------
OM_INIT_SUPERADMIN_EMAIL=superadmin@acme.com
OM_INIT_SUPERADMIN_PASSWORD=change-me-strong-admin-password

# ---- Images -----------------------------------------------------------------------------------
# The OM frontend image. Build it from an open-mercato checkout (see deploy/README.md) or point
# this at a registry image you pushed.
OM_APP_IMAGE=open-mercato/app:local
# The .NET backend image. `up -d --build` builds it from ../packages/dotnet; override to use a
# registry image instead.
DOTNET_IMAGE=open-mercato/dotnet:local
